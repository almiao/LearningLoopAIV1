{
  "name": "learning-loop-ai-v1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "stop": "bash stop-services.sh",
    "start": "bash start-services.sh",
    "restart": "bash stop-services.sh && bash start-services.sh",
    "restart:quick": "bash stop-services.sh && bash start-services.sh",
    "dev": "bash start-services.sh",
    "restart:full": "bash stop-services.sh && npm run build && bash start-services.sh",
    "build": "node scripts/project-tools.mjs build",
    "e2e:web:start-frontend": "npm run build --prefix frontend && sh -c 'cd frontend && node node_modules/next/dist/bin/next start -p ${E2E_FRONTEND_PORT:-13000}'",
    "test:e2e:browser": "playwright test",
    "test:e2e:browser:update": "playwright test --update-snapshots=all",
    "test:e2e:browser:headed": "playwright test --headed",
    "verify:real": "E2E_USE_EXISTING_SERVICES=1 E2E_FRONTEND_PORT=3000 E2E_BFF_PORT=4000 playwright test tests/e2e/focus-reading.pw.spec.js --workers=1",
    "deliver:real": "npm run restart:full && npm run verify:real",
    "test": "node scripts/project-tools.mjs test",
    "eval:auto": "node scripts/project-tools.mjs eval:auto",
    "validate:cases": "node scripts/project-tools.mjs validate:cases",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:bff": "npm run dev --prefix bff",
    "dev:superapp": "npm run dev --prefix superapp-service",
    "dev:ai": "python3 -m uvicorn app.main:app --reload --port 8000 --app-dir ai-service",
    "smoke:split": "node scripts/project-tools.mjs smoke:split"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
